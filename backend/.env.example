# ─── Backend Environment ──────────────────────────
PORT=5000

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/afridict

# JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET=change_this_to_a_secure_random_string

# Frontend URL (for CORS and payment redirects)
FRONTEND_URL=http://localhost:3000

# Polygon RPC (for blockchain listener)
POLYGON_RPC_URL=http://127.0.0.1:8545

# ─── Payment Gateways ─────────────────────────────
# Flutterwave (https://dashboard.flutterwave.com/settings/apis)
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxx

# Paystack (https://dashboard.paystack.com/#/settings/developers)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxx
